{
  "name": "polymorphia-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "eslint:check": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier:check": "prettier --check './**/*.{ts,js,tsx,scss,json}'",
    "prettier:fix": "prettier --write './**/*.{ts,js,tsx,scss,json}'",
    "lint": "npm run eslint:check && npm run prettier:check",
    "prepare": "cd .. && husky polymorphia-frontend/.husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,less,md,css,html}": "npx prettier --ignore-unknown --ignore-path .gitignore --ignore-path .prettierignore --write"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/material": "^9.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-form": "^1.31.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "case-anything": "^3.1.2",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "material-symbols": "^0.44.6",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.17",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-paginate": "^8.3.0",
    "react-refractor": "^4.0.0",
    "react-responsive": "^10.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "react-textarea-autosize": "^8.5.9",
    "refractor": "^5.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tanstack/eslint-plugin-query": "^5.100.9",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/webpack": "^5.28.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postcss-import": "^16.1.1",
    "postcss": "^8.5.17",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "vercel": {
    "framework": "nextjs"
  },
  "overrides": {
    "dompurify": "^3.2.6"
  }
